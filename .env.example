# PostgreSQL
POSTGRES_DB=oa_smart_audit
POSTGRES_USER=oa_admin
POSTGRES_PASSWORD=changeme_pg_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Go Service
JWT_SECRET=changeme_jwt_secret
ENCRYPTION_KEY=change-me-32-byte-key-in-prod!! # Must be exactly 32 bytes for AES-256
AI_SERVICE_URL=http://ai-service:8000
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_DBNAME=oa_smart_audit
DATABASE_USER=oa_admin
DATABASE_PASSWORD=changeme_pg_password
DATABASE_SSLMODE=disable
MONGO_URI=mongodb://mongodb:27017

# 日志配置（对应 config.yaml log.* 字段，Viper 自动将环境变量中的 _ 映射为 .）
# LOG_LEVEL: 日志等级，可选 debug / info / warn / error，生产环境建议 info
LOG_LEVEL=info
# LOG_DIR: 日志文件根目录（容器内路径，已通过 volumes 挂载到宿主机）
LOG_DIR=/app/logs
# LOG_MAX_SIZE_MB: 单个日志文件最大体积（MB），超出后触发轮转
LOG_MAX_SIZE_MB=100
# LOG_MAX_BACKUPS: 轮转后最多保留的备份文件数量。
# 设为 0（默认）表示不限数量，完全由天数配置控制；设为正整数可额外限制数量上限。
LOG_MAX_BACKUPS=0
# LOG_COMPRESS: 是否对备份文件进行 gzip 压缩（true/false）
LOG_COMPRESS=true
# LOG_GLOBAL_RETENTION_DAYS: 全局日志文件保留天数（兜底值，优先读数据库配置）
LOG_GLOBAL_RETENTION_DAYS=30

# TZ: 容器时区，影响日志时间戳显示，默认 Asia/Shanghai（北京时间）
TZ=Asia/Shanghai

# Python AI Service
LLM_PROVIDER=local
LLM_MODEL_NAME=default
LLM_API_KEY=

# Nuxt Frontend
NUXT_PUBLIC_API_BASE=http://localhost:8080
NUXT_PUBLIC_MOCK_MODE=true
